      "projectDashboardUrlType": "OrganizationKeyAndProjectGuid",
      "configurePath": "Project/Services/Authentication"
    },
    "supportedPlatforms": [
      "Android",
      "iOS",
      "Linux",
      "Mac",
      "PC",
      "WebGL",
